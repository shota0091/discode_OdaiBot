# =============================================================
# OdaiBotDB 環境変数ひな形
# プロジェクトルートの .env を参照します。
# setup_db.py 単体実行時はここに .env を作成してください。
# =============================================================

# -------------------------------------------------------------
# MySQL 接続設定
# setup_db.py はこれらの値を使って DB とテーブルを作成します。
# -------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=odai_bot
