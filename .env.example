# =============================================================
# OdaiBot 環境変数ひな形
# このファイルを .env にコピーして各値を設定してください。
# cp .env.example .env
# =============================================================

# -------------------------------------------------------------
# MySQL 接続設定（ローカル開発用デフォルト値）
# OdaiBotDB / OdaiBotAPI / OdaiBot が共通で使用します。
# MYSQL_PASSWORD はローカルの MySQL root パスワードに合わせてください。
# パスワードなしの場合は空のままにしてください。
# -------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=odai_bot

# -------------------------------------------------------------
# Discord Bot
# Discord Developer Portal で取得したトークンを設定してください。
# https://discord.com/developers/applications
# -------------------------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# -------------------------------------------------------------
# Dashboard
# 招待リンクの生成に使用します。
# 本番環境では公開 URL に変更してください。
# -------------------------------------------------------------
DASHBOARD_BASE_URL=http://localhost:3000

# -------------------------------------------------------------
# 招待トークン
# Dashboard の招待トークンの有効期限（時間単位）。
# -------------------------------------------------------------
INVITE_EXPIRE_HOURS=1

# -------------------------------------------------------------
# Stripe
# Stripe ダッシュボードで取得したキーを設定してください。
# https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET は Webhook エンドポイントごとに発行されます。
# -------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# -------------------------------------------------------------
# Bot 内部 API 認証
# Discord Bot が API を呼ぶ際に使用するシークレット。
# 任意の長いランダム文字列を設定してください。
# -------------------------------------------------------------
BOT_INTERNAL_SECRET=your_bot_internal_secret_here

# -------------------------------------------------------------
# Bot → API 内部通信
# Discord Bot が API サーバーを呼ぶときのベース URL。
# 本番環境では公開 URL に変更してください。
# -------------------------------------------------------------
API_BASE_URL=http://localhost:8000

# -------------------------------------------------------------
# デフォルトお題画像の保存先
# -------------------------------------------------------------
ODAI_IMAGE_DIR=/data/odai
DEFAULT_ODAI_IMAGE_DIR=/data/default_odai
