# =============================================================
# OdaiBot 環境変数ひな形
# プロジェクトルートの .env を参照します。
# モジュール単体で動かす場合はここに .env を作成してください。
# =============================================================

# -------------------------------------------------------------
# Discord Bot（必須）
# Discord Developer Portal で取得したトークンを設定してください。
# https://discord.com/developers/applications
# -------------------------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# -------------------------------------------------------------
# MySQL 接続設定（OdaiBotDB 経由で使用）
# -------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=odai_bot

# -------------------------------------------------------------
# Dashboard
# /odai_dashboard コマンドで発行する招待リンクのベース URL。
# -------------------------------------------------------------
DASHBOARD_BASE_URL=http://localhost:3000

# -------------------------------------------------------------
# 招待トークン有効期限（時間単位）
# -------------------------------------------------------------
INVITE_EXPIRE_HOURS=1
