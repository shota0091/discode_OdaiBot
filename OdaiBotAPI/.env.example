# =============================================================
# OdaiBotAPI 環境変数ひな形
# プロジェクトルートの .env を参照します。
# モジュール単体で動かす場合はここに .env を作成してください。
# =============================================================

# -------------------------------------------------------------
# MySQL 接続設定（OdaiBotDB 経由で使用）
# -------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=odai_bot

# -------------------------------------------------------------
# 招待トークン有効期限（時間単位）
# POST /auth/invite で発行されるトークンの有効時間。
# -------------------------------------------------------------
INVITE_EXPIRE_HOURS=1
